# --- FREE TIER LLM CONFIGURATION ---
# Recommended: Get a free API Key from Groq (https://console.groq.com)
# This allows for super-fast Llama-3 inference for free.
GROQ_API_KEY=

# Optional: Paid Models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- FREE TIER SEARCH CONFIGURATION ---
# DuckDuckGo search is integrated for FREE (no key needed).
# Optional: Tavily (Free for 1,000 searches/mo)
TAVILY_API_KEY=

# --- FREE MARKET DATA CONFIGURATION ---
# Polymarket CLOB API is free for market data.
# Optional: Trading Keys for live execution
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PROXY_ADDRESS=

# --- FREE BLOCKCHAIN RPC ---
# Already uses public Polygon RPC (https://polygon-rpc.com)
POLYGON_PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com
